[Unit]
Description=PrepSignal Backend (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=padiac
WorkingDirectory=/home/padiac/PrepSignal/backend
ExecStart=/home/padiac/PrepSignal/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
